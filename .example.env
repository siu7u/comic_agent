# Real image provider configuration
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_IMAGE_MODEL=wan2.7-image
DASHSCOPE_IMAGE_SIZE=2K

# LM-assisted planner configuration
COMIC_AGENT_LM_API_URL=https://example.com/v1/chat/completions
COMIC_AGENT_LM_API_KEY=your-lm-api-key
COMIC_AGENT_LM_MODEL=your-lm-model

# Optional planner defaults
# Leave unset to default to lm_assisted, or set to false/off/0 to default to rule_based.
COMIC_AGENT_LM_ENABLED=
COMIC_AGENT_LM_TIMEOUT=20
